/-- THE LEDGER LAW — proved core. Every field below is discharged by a named
    theorem of this lake in `the_ledger_law` (ten kernel-only; the maintenance
    clause names the three Dynamics substrate symbols). This is the maximal
    claim the lake makes with proof terms rather than asserted propositions —
    compare `MaximalClaim.maximal_claim`, whose audit shows one theorem and
    eleven asserted Props. Here: eleven theorems, zero asserted Props. -/
structure LedgerLawCore : Prop where
  /-- CLAUSE 1a (T-C1, arbitrary matrices). For every unit-diagonal PSD
      correlation structure: S ≥ 0, and S = 0 exactly at the vacuum C = 1 —
      the unique zero of the ledger, for every substrate presentation. -/
  vacuum_unique_zero : ∀ (k : ℕ) (C : Matrix (Fin k) (Fin k) ℝ),
    C.PosSemidef → IsUnitDiag C → 0 < C.det →
      0 ≤ entropicPotentialM C ∧ (entropicPotentialM C = 0 ↔ C = 1)
  /-- CLAUSE 1b (T-E1b). The rigidity pole: S → +∞ as ρ → 1⁻ — collapse is
      the divergence of the account, where statehood itself fails. -/
  collapse_pole : ∀ k : ℝ, 1 < k →
    Tendsto (fun ρ => entropicPotential k ρ) (nhdsWithin 1 (Set.Iio 1)) atTop
  /-- CLAUSE 1c (T-E2). Strictly monotone between the poles. -/
  monotone_between : ∀ k : ℝ, 1 < k →
    StrictMonoOn (fun ρ => entropicPotential k ρ) (Set.Ico (0:ℝ) 1)
  /-- CLAUSE 2a (T-E5c). The exchange rate: S = 2 × Gaussian multi-information
      — the joint-entropy deficit and the Stein detection exponent are S/2. -/
  exchange_rate_information : ∀ k ρ : ℝ, 1 ≤ k → 0 ≤ ρ → ρ < 1 →
    entropicPotential k ρ = 2 * gaussianMultiInformation k ρ
  /-- CLAUSE 2b (T-C0 bridge / T-E5b). The ledger is kept on the actual
      matrix: S(C(k,ρ)) = −ln det, derived, not assumed. -/
  exchange_rate_matrix : ∀ k : ℕ, 1 ≤ k → ∀ ρ : ℝ, 0 ≤ ρ → ρ < 1 →
    entropicPotentialM (kishMatrix k ρ) = entropicPotential (k : ℝ) ρ
  /-- CLAUSE 2c (T-E3). Per-unit entropy density saturates at −ln(1−ρ): the
      relative-entropy face of the Kish ceiling k_eff → 1/ρ. -/
  density_saturation : ∀ ρ : ℝ, 0 < ρ → ρ < 1 →
    Tendsto (fun k => entropicPotential k ρ / k) atTop
      (nhds (-Real.log (1 - ρ)))
  /-- CLAUSE 3 (T-L2). Only shape counts: the entropic post-selection weight
      is invariant under uniform amplitude rescaling — the one blindness that
      is the CMB orthogonality fence, the w = −1 fence, and the per-stream
      certification hole. -/
  copula_blindness : ∀ (β k : ℝ) (n : ℕ) (c : ℝ), c ≠ 0 → ∀ a : Fin n → ℝ,
    entropicWeightOfAmplitudes β k (fun i => c * a i)
      = entropicWeightOfAmplitudes β k a
  /-- CLAUSE 4 (base case; Oppenheim k = 2). Local processing cannot create
      coordination: the Hadamard (local-transform) product does not lower the
      determinant — the concrete base of the DPI chain, whose general closure
      is roadmapped in `Core.EntropicContraction`. -/
  local_noncreation_base : ∀ a b : ℝ, |a| ≤ 1 → |b| ≤ 1 →
    (Matrix.hadamard !![1, a; a, 1] !![1, b; b, 1] :
        Matrix (Fin 2) (Fin 2) ℝ).det
      ≥ (!![1, a; a, 1] : Matrix (Fin 2) (Fin 2) ℝ).det
  /-- CLAUSE 5 (Core.Dynamics). The interior is rented: at any equilibrium the
      maintenance work exactly pays the drift, γ·M = α. -/
  maintenance_rent : ∀ (ρ : ℝ) (Sp : Dynamics.SelectionPressure) (t : ℝ),
    Dynamics.dρ_dt ρ Sp t = 0 → Dynamics.γ * Dynamics.M t = Dynamics.α ρ Sp
  /-- CLAUSE 6 (T-L1). The vacuum is stationary: deviations are second order
      with coefficient k(k−1)/2 — the protection of the GR/ΛCDM limit and its
      first-order untestability, as one theorem. -/
  vacuum_stationary : ∀ k : ℝ, 1 ≤ k →
    SecondOrderDeviation (entropicPotential k) (k * (k - 1) / 2)
  /-- THE PERMITTED HISTORY (T-P3f). An ascent trajectory opens the books at
      the unique zero, at the global minimum, strictly ascends, and never
      attains the pole. Why the books open at zero is NOT explained — it is
      the assumption `EntropicAscent.vacuum_start` (Penrose's puzzle,
      relocated, not solved). -/
  opening_and_ascent : ∀ k : ℝ, 1 < k → ∀ ρ : ℝ → ℝ, EntropicAscent ρ →
    entropicPotential k (ρ 0) = 0 ∧
    (∀ σ ∈ Set.Ico (0:ℝ) 1, entropicPotential k (ρ 0) ≤ entropicPotential k σ) ∧
    (∀ s t : ℝ, 0 ≤ s → s < t →
      entropicPotential k (ρ s) < entropicPotential k (ρ t)) ∧
    (∀ t : ℝ, 0 ≤ t → ρ t < 1)

/-- THE LEDGER LAW HOLDS — by discharge, not assertion. Eleven conjuncts,
    eleven theorems. AXIOM AUDIT, stated precisely: ten conjuncts are
    kernel-only [propext, Classical.choice, Quot.sound]; the maintenance
    clause additionally MENTIONS the three `Core.Dynamics` substrate
    primitives (α, γ, M) — uninterpreted function SYMBOLS (signatures), not
    asserted PROPOSITIONS. A symbol cannot make anything false; the eleven
    `MaximalClaim` assertions were asserted Props. The distinction is the
    difference between naming a quantity and claiming a truth about it. -/
theorem the_ledger_law : LedgerLawCore where
  vacuum_unique_zero := fun _ _ hC hd hdet =>
    ⟨entropicPotentialM_nonneg hC hd hdet,
     entropicPotentialM_eq_zero_iff hC hd hdet⟩
  collapse_pole := entropicPotential_tendsto_atTop_rigidity
  monotone_between := entropicPotential_strictMonoOn
  exchange_rate_information := fun k ρ hk hρ0 hρ1 =>
    entropicPotential_eq_two_mul_multiInformation k ρ hk hρ0 hρ1
  exchange_rate_matrix := fun k hk ρ hρ0 hρ1 =>
    entropicPotentialM_kishMatrix k hk ρ hρ0 hρ1
  density_saturation := fun ρ hρ0 hρ1 => entropicPotential_density ρ hρ0 hρ1
  copula_blindness := fun β k _ c hc a =>
    entropicWeightOfAmplitudes_scale_invariant β k c hc a
  local_noncreation_base := fun a b ha hb => oppenheim_two a b ha hb
  maintenance_rent := fun ρ Sp t h => Dynamics.corridor_requires_maintenance ρ Sp t h
  vacuum_stationary := fun k hk => entropicPotential_secondOrderDeviation k hk
  opening_and_ascent := fun k hk ρ h => permitted_history k hk ρ h

